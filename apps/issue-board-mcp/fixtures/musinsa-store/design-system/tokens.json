{
  "meta": {
    "name": "Musinsa Store DS",
    "version": "0.1.0",
    "platform": ["iOS", "Android", "Web"],
    "density": "comfortable"
  },
  "color": {
    "brand": {
      "primary": "#111111",
      "primaryInverse": "#FFFFFF",
      "accent": "#FF4800",
      "accentMuted": "#FFF0EB"
    },
    "neutral": {
      "0": "#FFFFFF",
      "50": "#FAFAFA",
      "100": "#F5F5F5",
      "200": "#E8E8E8",
      "300": "#D4D4D4",
      "400": "#A3A3A3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717",
      "950": "#0A0A0A"
    },
    "semantic": {
      "success": "#16A34A",
      "warning": "#D97706",
      "danger": "#DC2626",
      "info": "#2563EB",
      "sale": "#FF4800",
      "soldOut": "#A3A3A3"
    },
    "surface": {
      "canvas": "#FFFFFF",
      "elevated": "#FFFFFF",
      "sunken": "#FAFAFA",
      "overlay": "rgba(17,17,17,0.48)"
    },
    "border": {
      "subtle": "#F5F5F5",
      "default": "#E8E8E8",
      "strong": "#D4D4D4"
    },
    "text": {
      "primary": "#111111",
      "secondary": "#525252",
      "tertiary": "#A3A3A3",
      "inverse": "#FFFFFF",
      "link": "#111111",
      "sale": "#FF4800"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Pretendard", "Apple SD Gothic Neo", "system-ui", "sans-serif"],
      "mono": ["JetBrains Mono", "ui-monospace", "monospace"]
    },
    "scale": {
      "display": { "size": 28, "lineHeight": 36, "weight": 700, "tracking": -0.4 },
      "title1": { "size": 22, "lineHeight": 28, "weight": 700, "tracking": -0.2 },
      "title2": { "size": 18, "lineHeight": 24, "weight": 600, "tracking": -0.1 },
      "title3": { "size": 16, "lineHeight": 22, "weight": 600, "tracking": 0 },
      "body": { "size": 15, "lineHeight": 22, "weight": 400, "tracking": 0 },
      "bodyStrong": { "size": 15, "lineHeight": 22, "weight": 600, "tracking": 0 },
      "caption": { "size": 13, "lineHeight": 18, "weight": 400, "tracking": 0 },
      "captionStrong": { "size": 13, "lineHeight": 18, "weight": 600, "tracking": 0 },
      "micro": { "size": 11, "lineHeight": 14, "weight": 500, "tracking": 0.2 }
    }
  },
  "space": {
    "unit": 4,
    "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64]
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "pill": 999
  },
  "elevation": {
    "0": "none",
    "1": "0 1px 2px rgba(17,17,17,0.06)",
    "2": "0 4px 12px rgba(17,17,17,0.08)",
    "3": "0 12px 32px rgba(17,17,17,0.12)"
  },
  "motion": {
    "duration": { "fast": 120, "normal": 200, "slow": 320 },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "emphasized": "cubic-bezier(0.2, 0, 0, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)"
    }
  },
  "breakpoint": {
    "sm": 375,
    "md": 768,
    "lg": 1024
  },
  "components": {
    "Button": {
      "variants": ["primary", "secondary", "ghost", "danger"],
      "sizes": ["sm", "md", "lg"],
      "rules": [
        "primary = brand.primary bg + inverse text",
        "구매 CTA는 화면당 1개 primary 권장",
        "disabled opacity 0.4, pointer-events none"
      ]
    },
    "Chip": {
      "variants": ["filter", "sale", "rank"],
      "rules": ["선택 시 border.strong + bodyStrong"]
    },
    "ProductCard": {
      "aspectRatio": "3/4",
      "slots": ["image", "brand", "name", "price", "saleBadge", "wish"],
      "rules": ["이미지 lazy, CLS 방지용 고정 ratio", "할인율은 accent color"]
    },
    "TopNav": {
      "height": 56,
      "slots": ["back|logo", "title", "actions"]
    },
    "TabBar": {
      "height": 56,
      "items": ["홈", "카테고리", "검색", "좋아요", "마이"]
    },
    "BottomSheet": {
      "radius": "xl",
      "maxHeight": "90vh"
    },
    "Price": {
      "rules": [
        "정가 line-through + tertiary",
        "할인가 bodyStrong + primary",
        "할인율 captionStrong + sale"
      ]
    }
  }
}
